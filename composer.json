{
    "name": "tommcfarlin/mute-menu-notifications",
    "description": "Allows you to mute the notifications in the WordPress admin menu.",
    "type": "wordpress-plugin",
    "license": "GPL-3.0-or-later",
    "homepage": "https://github.com/tommcfarlin/mute-menu-notifications/",
    "authors": [
        {
            "name": "Tom McFarlin",
            "email": "tom@tommcfarlin.com",
            "homepage": "https://tommcfarlin.com"
        }
    ],
    "support": {
        "issues": "https://github.com/tommcfarlin/mute-menu-notifications/issues"
    },
    "config": {
        "vendor-dir": "vendor",
        "preferred-install": "dist",
        "platform": {
            "php": "7.4"
        },
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.5",
        "wp-coding-standards/wpcs": "^3.0",
        "phpunit/phpunit": "^9.6",
        "brain/monkey": "^2.6"
    },
    "autoload": {
        "psr-4": {
            "TomMcFarlin\\MMN\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "TomMcFarlin\\MMN\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "lint": "phpcs",
        "lint:fix": "phpcbf"
    },
    "minimum-stability": "stable"
}
